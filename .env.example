# =======================================================
# .env final pour Projet Mobile (React/Capacitor) + Django
# =======================================================

# --- 1. Configuration des Ports ---
BACKEND_PORT=8002
DB_PORT=8062
PGADMIN_PORT=8072
ADMINER_PORT=8082


# --- 2. Configuration Django ---
# Générez une clé avec : python manage.py shell -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=generate_secret_key
DEBUG=True

#JWT Settings
JWT_PRIVATE_KEY="PRIVATE_KEY"
JWT_PUBLIC_KEY="PUBLIC_KEY"



# IMPORTANT : Ajoute l'IP locale de ton ordinateur pour que ton téléphone (en Wi-Fi) 
# puisse contacter le serveur Django. Exemple: 192.168.1.XX
ALLOWED_HOSTS=localhost,127.0.0.1,nde-backend,192.168.1.65,192-168-1-65.sslip.io
# --- 3. Configuration Base de Données ---
POSTGRES_DB=""
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_HOST=""
POSTGRES_PORT=5432 

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# --- 4. Configuration CORS (Indispensable pour Capacitor) ---
# On ajoute les protocoles spécifiques à iOS (capacitor://) et Android (http://localhost)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://192.168.1.65:8080,http://192-168-1-65.sslip.io:8080,capacitor://localhost
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=accept,authorization,content-type,user-agent,x-csrftoken,x-requested-with

# --- 5. Authentification Google OAuth ---
# Note : Tu devras créer ces IDs dans la console Google Cloud
GOOGLE_WEB_CLIENT_ID="google_web_client_id"
GOOGLE_ANDROID_CLIENT_ID="google_android_client_id"
# GOOGLE_IOS_CLIENT_ID=votre_client_id_ios.apps.googleusercontent.com
SOCIALACCOUNT_GOOGLE_SECRET="google_secret"
GOOGLE_OAUTH_CALLBACK_URL=http://192.168.1.65:8080/login
# --- 6. Notifications Push (Firebase FCM) ---
# Chemin vers le fichier JSON de service téléchargé depuis Firebase
FIREBASE_SERVICE_ACCOUNT_JSON="secrets/firebase_service_account.json"
# Clé de serveur (si tu utilises djangofcm ou similaire)
# FCM_SERVER_KEY=votre_cle_serveur_fcm_ici
FCM_SENDER_ID="fcm_sender_id"


#configuration des emails (pour les notifications, réinitialisation de mot de passe, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER="email_user"
EMAIL_HOST_PASSWORD="email_password"
DEFAULT_FROM_EMAIL="email_user"


# --- Pass contacts locataires (KPay Sandbox — mode GATEWAY, page de paiement hébergée) ---
# BACKEND_PUBLIC_URL n'est utile QUE pour recevoir le webhook KPay (voir plus bas) : sans tunnel
# public (ngrok ou équivalent), laisse la valeur par défaut http://127.0.0.1:8002 — le paiement
# reste testable en local (init + redirection + retour), seul le webhook ne sera pas reçu.
BACKEND_PUBLIC_URL=http://127.0.0.1:8002
# FRONTEND_PUBLIC_URL doit rester joignable par le NAVIGATEUR du client (localhost convient
# très bien en local : c'est un aller-retour navigateur, pas un appel serveur→serveur).
FRONTEND_PUBLIC_URL=http://localhost:8080
CONTACT_ACCESS_FREE_VIEWS=5
CONTACT_ACCESS_PRICE_XAF=500
CONTACT_ACCESS_SUBSCRIPTION_DAYS=30

# Racine officielle (identique sandbox/prod, seul le préfixe des clés change) :
KPAY_API_BASE_URL=https://admin.kpay.site
# Clés du tableau de bord KPay : kpay_test_… / sk_test_… en sandbox, kpay_live_… / sk_live_… en prod.
KPAY_API_KEY=
KPAY_SECRET_KEY=

KPAY_PAYMENT_DESCRIPTION=Pass contacts annonces NDE

# --- Webhook (optionnel en dev local) ---
# KPay (serveur) doit pouvoir appeler cette URL depuis internet : localhost/127.0.0.1 est donc
# TOUJOURS insuffisant, avec ou sans variable d'env — il faut soit un tunnel public (ngrok...),
# soit un vrai domaine déployé. Sans tunnel, laisse les champs de callback VIDES dans le tableau
# de bord KPay (aucune erreur : KPay n'envoie simplement pas de notification) ; la confirmation
# du paiement passe alors uniquement par le retour signé + polling GET /payments/:id
# (ContactAccessKPayReturnView), suffisant pour tester le flux tant que l'utilisateur revient
# bien sur /profile/payments après paiement.
#   URL à déclarer une fois un tunnel/domaine public disponible :
#   {BACKEND_PUBLIC_URL}/api/nde/payments/kpay/webhook/
# Secret utilisé par KPay pour signer le webhook (en-tête X-KPAY-Signature, HMAC-SHA256 sur le corps brut).
KPAY_WEBHOOK_SECRET=

# Secret de signature du retour passerelle (status|reference|externalId|ts). Laisser vide pour
# retomber sur KPAY_SECRET_KEY — à ajuster si le tableau de bord KPay fournit un secret distinct.
KPAY_GATEWAY_SECRET=
KPAY_WEBHOOK_SIGNATURE_HEADER=X-KPAY-Signature

# --- Stockage fichiers (Cloudinary) ---
# Tant que les 3 valeurs ne sont pas renseignées, l'app reste sur le stockage disque local
# (media/) comme aujourd'hui — rien à faire pour continuer en dev sans compte Cloudinary.
# Une fois renseignées, TOUS les nouveaux fichiers uploadés (photos, documents) partent sur
# Cloudinary ; les fichiers déjà sur disque local ne sont PAS migrés automatiquement.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- 7. Configuration Celery ---
# Broker/backend Redis, fourni par le service "nde-redis" de compose.yaml.
CELERY_BROKER_URL=redis://nde-redis:6379/0
CELERY_RESULT_BACKEND=redis://nde-redis:6379/0